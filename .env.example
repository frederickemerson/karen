# Karen cloud/auth configuration.
# Copy to .env.local for local development. Do not commit real secrets.

# Convex
CONVEX_DEPLOYMENT=
CONVEX_DEPLOY_KEY=
VITE_CONVEX_URL=
NEXT_PUBLIC_CONVEX_URL=
CONVEX_HTTP_ACTIONS_URL=
VITE_CONVEX_HTTP_ACTIONS_URL=
CONVEX_SITE_URL=
VITE_CONVEX_SITE_URL=
KAREN_CLOUD_SYNC=0
KAREN_CLOUD_INGEST_SECRET=

# Clerk
# This repo is Vite-based, so VITE_CLERK_PUBLISHABLE_KEY is the browser env name.
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY is listed for future Next.js packaging compatibility.
VITE_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER_DOMAIN=

# Optional ElevenLabs support for Karen roasts, voice casting, and sound effects.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_v3
KAREN_AUDIO_CACHE=1
KAREN_AUDIO_DEMO_MODE=0
KAREN_ELEVENLABS_AUDIO=1
KAREN_ELEVENLABS_DAILY_CAP=20000

# Optional OpenAI-backed quiz generation. Parser questions remain the fallback.
OPENAI_API_KEY=
KAREN_QUIZ_AI=1
KAREN_QUIZ_MODEL=gpt-5.5
KAREN_QUIZ_REASONING_EFFORT=high
KAREN_QUIZ_TIMEOUT_MS=25000

# Public deployment URL once hosted.
PUBLIC_APP_URL=
