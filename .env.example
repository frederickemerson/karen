# Karen cloud/auth configuration.
# Copy to .env.local for local development. Do not commit real secrets.

# Convex
CONVEX_DEPLOYMENT=
CONVEX_DEPLOY_KEY=
VITE_CONVEX_URL=
NEXT_PUBLIC_CONVEX_URL=
CONVEX_HTTP_ACTIONS_URL=
VITE_CONVEX_HTTP_ACTIONS_URL=
CONVEX_SITE_URL=
VITE_CONVEX_SITE_URL=
KAREN_CLOUD_SYNC=0
KAREN_CLOUD_INGEST_SECRET=

# Clerk
# This repo is Vite-based, so VITE_CLERK_PUBLISHABLE_KEY is the browser env name.
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY is listed for future Next.js packaging compatibility.
VITE_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER_DOMAIN=

# Optional future ElevenLabs support.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Public deployment URL once hosted.
PUBLIC_APP_URL=
